AWS_REGION=us-west-2
FAMILY_DDB_TABLE=
FAMILY_USE_IN_MEMORY_DB=true
# Local dev with real data (no AWS login): set FAMILY_USE_IN_MEMORY_DB=false,
# FAMILY_DDB_TABLE=mcpeak, and FAMILY_USE_COGNITO_CREDENTIALS=true
FAMILY_USE_COGNITO_CREDENTIALS=false
# Production requires FAMILY_LOGIN_ANSWER; local dev can leave it empty to use
# the legacy hash-based reunion city check.
FAMILY_LOGIN_ANSWER=
FAMILY_SESSION_SECRET=replace-with-a-long-random-secret

# Production site (https://mcpeakfamily.org)
CANONICAL_HOST=mcpeakfamily.org
NEXT_PUBLIC_SITE_URL=https://mcpeakfamily.org
