# Copy to your shell before running Amplify CLI scripts:
#   export AWS_PROFILE=mcpeak-family
#   source .env.amplify.example  # or export vars manually

AWS_PROFILE=mcpeak-family
AWS_REGION=us-west-2
AMPLIFY_APP_NAME=mcpeak-family
GITHUB_REPO=https://github.com/jmcpeak/family.git
GITHUB_BRANCH=main
DOMAIN_NAME=mcpeakfamily.org
FAMILY_DDB_TABLE=mcpeak

# GitHub personal access token (repo scope) — required for CLI-connected GitHub deploys
# GITHUB_TOKEN=ghp_...

# Optional: skip domain setup on first run
# SETUP_DOMAIN=false
