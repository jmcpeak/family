{
  "name": "family",
  "version": "4.0.0",
  "description": "McPeak family directory modernized with Next.js and React.",
  "private": true,
  "scripts": {
    "dev": "next dev --experimental-https",
    "dev:http": "next dev",
    "build": "next build",
    "analyze": "ANALYZE=true next build --webpack",
    "perf:baseline": "node scripts/perf-baseline.mjs",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "playwright test --config playwright.config.ts",
    "test:smoke:staging": "SMOKE_ALLOW_WRITES=true playwright test --config playwright.config.ts",
    "coverage:check": "node scripts/check-coverage-thresholds.mjs",
    "validate": "npm run lint && npm run typecheck && npm run test && npm run test:coverage && npm run coverage:check",
    "amplify:setup": "bash scripts/amplify-setup.sh",
    "amplify:status": "bash scripts/amplify-status.sh",
    "amplify:deploy": "bash scripts/amplify-deploy.sh",
    "amplify:verify": "bash scripts/verify-launch-readiness.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmcpeak/family.git"
  },
  "keywords": [
    "nextjs",
    "react",
    "dynamodb"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "bugs": {
    "url": "https://github.com/jmcpeak/family/issues"
  },
  "homepage": "https://github.com/jmcpeak/family#readme",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "3.1090.0",
    "@aws-sdk/credential-provider-cognito-identity": "3.972.58",
    "@aws-sdk/lib-dynamodb": "3.1090.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "9.2.0",
    "@mui/material": "9.2.0",
    "@mui/material-nextjs": "9.1.1",
    "@tanstack/react-query": "5.101.2",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "jsdom": "29.1.1",
    "typescript": "^6.0.3",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  },
  "overrides": {
    "@mui/material-nextjs": {
      "next": "$next"
    },
    "postcss": "^8.5.10"
  },
  "allowScripts": {
    "fsevents": true,
    "sharp": true
  }
}
