{
  "name": "family",
  "version": "3.0.0",
  "description": "McPeak family directory modernized with Next.js and React.",
  "private": true,
  "scripts": {
    "dev": "next dev --experimental-https",
    "dev:http": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "amplify:setup": "bash scripts/amplify-setup.sh",
    "amplify:status": "bash scripts/amplify-status.sh",
    "amplify:deploy": "bash scripts/amplify-deploy.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmcpeak/family.git"
  },
  "keywords": [
    "nextjs",
    "react",
    "dynamodb"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "bugs": {
    "url": "https://github.com/jmcpeak/family/issues"
  },
  "homepage": "https://github.com/jmcpeak/family#readme",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "3.1086.0",
    "@aws-sdk/credential-provider-cognito-identity": "^3.972.56",
    "@aws-sdk/lib-dynamodb": "3.1086.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "9.2.0",
    "@mui/material": "9.2.0",
    "@mui/material-nextjs": "9.1.1",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
